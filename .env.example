# ============================================
# MIMOO WEB - Environment Variables Template
# ============================================
# Copy this file to .env.local and fill in the values
# JANGAN commit .env.local ke repo!

# ============================================
# 🔐 SUPABASE (REQUIRED untuk auth)
# ============================================
# 1. Buat project gratis di https://supabase.com/dashboard
# 2. Settings → API → copy URL & keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# 🔑 CRYPTO SECRET (REQUIRED)
# ============================================
# Generate dengan: openssl rand -base64 32
# Untuk encrypt sensitive data (lost mode contact, dll)
CRYPTO_SECRET_KEY=your-32-char-secret-key-here

# ============================================
# 🌐 APP CONFIGURATION
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Mimoo
NEXT_PUBLIC_DEFAULT_LOCALE=id

# ============================================
# 🔵 GOOGLE OAUTH SETUP (untuk "Login with Google")
# ============================================
# Tidak perlu di-set di .env! Configured langsung di Supabase Dashboard.
#
# Cara setup:
# 1. Pergi ke https://console.cloud.google.com/
# 2. Buat project baru (atau pilih yang ada)
# 3. APIs & Services → Credentials → Create OAuth Client ID
# 4. Application type: "Web application"
# 5. Authorized redirect URIs (tambah semuanya):
#    - https://<your-project-id>.supabase.co/auth/v1/callback
#    - http://localhost:3000/auth/callback (untuk dev)
#    - https://your-domain.com/auth/callback (untuk production)
# 6. Copy Client ID & Client Secret
# 7. Di Supabase Dashboard: Authentication → Providers → Google
#    Enable Google, paste Client ID & Client Secret, save
#
# Test: buka /login → klik "Continue with Google" → should redirect ke Google
# 
# Tutorial detail: https://supabase.com/docs/guides/auth/social-login/auth-google

# ============================================
# 📧 EMAIL NOTIFICATIONS (Resend) — Phase 4
# ============================================
# Resend = email service yang easy + free tier 100/hari
#
# Cara setup:
# 1. Sign up gratis di https://resend.com
# 2. Verify your domain (atau pakai onboarding@resend.dev untuk testing)
# 3. Dashboard → API Keys → Create API Key → copy
# 4. Paste di RESEND_API_KEY di bawah
#
# Untuk dev (tanpa domain), pakai:
#   EMAIL_FROM=onboarding@resend.dev
#   (cuma bisa kirim ke email yang sama dengan akun Resend kamu)
#
# Untuk production, beli/verify domain & set:
#   EMAIL_FROM=hello@mimoo.id
#
# Kalau RESEND_API_KEY kosong, email notification akan di-skip (gak error, just no-op)
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=Mimoo
