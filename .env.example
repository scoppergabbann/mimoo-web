# ============================================
# MIMOO WEB - Environment Variables Template
# ============================================
# Copy this file to .env.local and fill in the values
# JANGAN commit .env.local ke repo!

# === Supabase Configuration ===
# Dapatkan dari: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# === CryptoJS Secret ===
# Generate dengan: openssl rand -base64 32
# Digunakan untuk encrypt sensitive user data (lost mode contact, dll)
CRYPTO_SECRET_KEY=your-32-char-secret-key-here

# === App Configuration ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Mimoo
NEXT_PUBLIC_DEFAULT_LOCALE=id

# === Google OAuth (untuk Phase berikutnya) ===
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# === Email Service (untuk notifikasi - Phase berikutnya) ===
# RESEND_API_KEY=
# EMAIL_FROM=hello@mimoo.id
